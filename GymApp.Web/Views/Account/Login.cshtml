@{
    ViewData["Title"] = "Login";
}

<style>
    /* The Arrow App Aesthetic */
    body {
        background-color: #0b0f19 !important;
        color: #ffffff !important;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .login-container {
        max-width: 400px;
        margin: 80px auto;
        padding: 30px;
        background-color: #1a1f2e;
        border-radius: 20px;
        border: 1px solid #2a3143;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .arrow-brand {
        text-align: center;
        margin-bottom: 30px;
    }

    .arrow-icon {
        font-size: 3rem;
        background: -webkit-linear-gradient(#10b981, #059669);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .form-control-dark {
        background-color: #0b0f19;
        border: 1px solid #2a3143;
        color: white;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 20px;
        width: 100%;
    }

        .form-control-dark:focus {
            background-color: #0b0f19;
            border-color: #10b981;
            color: white;
            outline: none;
            box-shadow: 0 0 0 0.25rem rgba(16, 185, 129, 0.25);
        }

    /* The Neon Green Arrow Button */
    .arrow-btn-success {
        background-color: #10b981;
        color: #0b0f19;
        border: none;
        border-radius: 14px;
        font-weight: 800;
        font-size: 1.1rem;
        padding: 15px;
        width: 100%;
        transition: transform 0.2s, opacity 0.2s;
    }

        .arrow-btn-success:hover {
            transform: scale(1.02);
            opacity: 0.9;
            color: #0b0f19;
        }
</style>

<div class="login-container">
    <div class="arrow-brand">
        <h1 class="arrow-icon">💪</h1>
        <h2 style="font-weight: 800;">Welcome Back</h2>
        <p style="color: #64748b;">Log in to track your EXP.</p>
    </div>

    <form method="post" asp-action="Login">
        <div asp-validation-summary="All" class="text-danger mb-3 text-center" style="font-weight: 600; color: #ef4444;"></div>
        <input type="email" name="email" class="form-control-dark" placeholder="Email address" required />
        <input type="password" name="password" class="form-control-dark" placeholder="Password" required />
        <div class="form-check mb-4" style="text-align: left;">
            <input class="form-check-input" type="checkbox" name="rememberMe" value="true" id="rememberMe" style="background-color: #1a1f2e; border-color: #2a3143;">
            <label class="form-check-label" for="rememberMe" style="color: #64748b; font-weight: 600;">
                Remember Me
            </label>
        </div>
        <button type="submit" class="arrow-btn-success mt-3">
            Start Session
        </button>
    </form>
    <div class="text-center mt-4">
        <p style="color: #64748b;">Don't have an account?</p>
        <a asp-controller="Account" asp-action="Register" style="color: #10b981; text-decoration: none; font-weight: 600;">Create a Profile</a>
    </div>
</div>