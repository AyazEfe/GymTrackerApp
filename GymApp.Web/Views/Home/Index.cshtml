@model GymApp.Web.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    body {
        background-color: #0b0f19 !important;
        color: #ffffff !important;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .profile-card {
        background-color: #1a1f2e;
        border-radius: 20px;
        padding: 30px;
        margin-top: 40px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        border: 1px solid #2a3143;
    }

    .avatar-circle {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: 800;
        color: #0b0f19;
        margin: 0 auto 15px auto;
        box-shadow: 0 0 20px rgba(16, 185, 129, 0.4);
    }

    .stat-box {
        background-color: #0b0f19;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        border: 1px solid #2a3143;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 800;
        color: #3b82f6; /* Blue for the EXP/Stats */
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 5px;
    }

    .exp-bar-container {
        height: 12px;
        background-color: #0b0f19;
        border-radius: 10px;
        margin-top: 15px;
        overflow: hidden;
        border: 1px solid #2a3143;
    }

    .exp-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #3b82f6, #60a5fa);
        border-radius: 10px;
    }
</style>

<div class="container">
    <div class="profile-card">
        <div class="avatar-circle">
            @(!string.IsNullOrWhiteSpace(Model?.Name) ? Model.Name.Substring(0, 1).ToUpper() : "?")
        </div>
        <h2 class="text-center" style="font-weight: 800; margin-bottom: 5px;">@Model?.Name</h2>
        <p class="text-center" style="color: #64748b; font-weight: 600;">Level @Model.Level Lifter</p>

        @{
            // Calculate the percentage! (We use 'double' so C# doesn't round it down to zero)
            double expPercentage = ((double)Model.CurrentExp / Model.MaxExp) * 100;
        }

        <div class="mt-4 mb-5">
            <div class="d-flex justify-content-between mb-2" style="font-size: 0.85rem; color: #94a3b8; font-weight: 600;">
                <span>EXP</span>
                <span>@Model.CurrentExp / @Model.MaxExp</span>
            </div>
            <div class="exp-bar-container">
                <div class="exp-bar-fill" style="width: @expPercentage%; transition: width 0.5s ease-in-out;"></div>
            </div>
        </div>

        <div class="row g-2 text-center">
            <div class="col-4">
                <div class="stat-box" style="padding: 15px 5px;">
                    <div class="stat-value" style="font-size: 1.5rem;">@Model.TotalWorkouts</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Workouts</div>
                </div>
            </div>
            <div class="col-4">
                <div class="stat-box" style="padding: 15px 5px;">
                    <div class="stat-value" style="font-size: 1.5rem; color: #f59e0b;">@Model.TotalTimeHours</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Time (minutes)</div>
                </div>
            </div>
            <div class="col-4">
                <div class="stat-box" style="padding: 15px 5px;">
                    <div class="stat-value" style="font-size: 1.5rem; color: #10b981;">@Model.TotalVolume</div>
                    <div class="stat-label" style="font-size: 0.75rem;">Vol (kg)</div>
                </div>
            </div>
        </div>
        <div class="text-center mt-4 pt-3" style="border-top: 1px solid #2a3143;">
            <a asp-controller="Account" asp-action="Logout" style="color: #ef4444; text-decoration: none; font-weight: 600;">
                Log Out
            </a>
        </div>
    </div>
</div>