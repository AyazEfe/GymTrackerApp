<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        /* Global Dark Mode Rules */
        body {
            background-color: #0b0f19 !important;
            color: #ffffff !important;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin-bottom: 80px; /* Space for the bottom nav bar */
        }

        /* The App-Style Bottom Navigation Bar */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background-color: #0b0f19; /* Matched exactly to the body background! */
            display: flex;
            justify-content: space-around;
            padding: 15px 0;
            z-index: 1000;
        }

        .nav-item {
            text-align: center;
            color: #64748b;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            transition: color 0.2s;
        }

            .nav-item:hover, .nav-item.active {
                color: #10b981; /* Neon green when active/hovered */
            }

        .nav-icon {
            font-size: 1.5rem;
            display: block;
            margin-bottom: 2px;
        }
    </style>
</head>
<body>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    @if (User.Identity.IsAuthenticated)
    {
        <nav class="bottom-nav">
            <a asp-controller="Home" asp-action="Index" class="nav-item">
                <span class="nav-icon">👤</span>
                Profile
            </a>
            <a asp-controller="Workout" asp-action="Index" class="nav-item">
                <span class="nav-icon">🔥</span>
                Workouts
            </a>
            <a asp-controller="Exercise" asp-action="Index" class="nav-item">
                <span class="nav-icon">📚</span>
                Library
            </a>
        </nav>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>