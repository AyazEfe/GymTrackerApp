@model GymApp.Entities.WorkoutSession

<div class="container text-white mt-4" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <a asp-action="Index" asp-fragment="history" class="btn btn-dark" style="border-radius: 50%; width: 40px; height: 40px; background-color: #1e293b; border: none;">&lt;</a>
        <h2 class="mb-0" style="font-weight: 800;">@Model.RoutineName</h2>
        <div style="width: 40px;"></div>
    </div>

    <div class="text-center mb-4" style="color: #64748b; font-size: 0.95rem;">
        @Model.Date.ToString("MM/dd/yy") &bull; @Model.DurationMinutes min &bull; @Model.TotalVolume kgs
    </div>

    @if (ViewBag.Details != null)
    {
        foreach (var ex in ViewBag.Details)
        {
            <div class="card mb-3" style="background-color: #1a1a2e; border: 1px solid #2d2d44; border-radius: 12px;">
                <div class="card-body">
                    <h5 style="color: #10b981; font-weight: bold; margin-bottom: 15px;">@ex.Name</h5>

                    <div class="row text-muted mb-2" style="font-size: 0.85rem; font-weight: bold; letter-spacing: 1px;">
                        <div class="col-2 text-center">SET</div>
                        <div class="col-5 text-center">KGS</div>
                        <div class="col-5 text-center">REPS</div>
                    </div>

                    @{
                        int setNum = 1;
                    }
                    @foreach (var set in ex.Sets)
                    {
                        <div class="row mb-2" style="font-size: 1.1rem; font-weight: 600;">
                            <div class="col-2 text-center text-muted">@setNum</div>
                            <div class="col-5 text-center">@set.Kgs</div>
                            <div class="col-5 text-center">@set.Reps</div>
                        </div>
                        setNum++;
                    }
                </div>
            </div>
        }
    }
</div>