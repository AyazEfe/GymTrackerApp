@model GymApp.Entities.WorkoutPlan

@{
    ViewData["Title"] = Model.Name;
}

<style>
    body {
        background-color: #0b0f19 !important;
        color: #ffffff !important;
    }

    .builder-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid #2a3143;
    }

    .exercise-list-item {
        background-color: #1a1f2e;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #2a3143;
    }

    .btn-add-exercise {
        background-color: #2a3143;
        color: #3b82f6;
        border: 1px dashed #3b82f6;
        border-radius: 16px;
        font-weight: 700;
        padding: 15px;
        width: 100%;
        margin-bottom: 20px;
        display: block;
        text-align: center;
        text-decoration: none;
    }

        .btn-add-exercise:hover {
            background-color: #1e293b;
            color: #3b82f6;
        }

    .btn-start-massive {
        background-color: #10b981;
        color: #0b0f19;
        border: none;
        border-radius: 16px;
        font-weight: 800;
        font-size: 1.2rem;
        padding: 18px;
        width: 100%;
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
        display: block;
        text-align: center;
        text-decoration: none;
    }

    .btn-delete-routine {
        background-color: transparent;
        color: #ef4444;
        border: 1px solid #ef4444;
        border-radius: 8px;
        padding: 8px 12px;
        font-weight: bold;
        font-size: 0.9rem;
        transition: 0.2s;
    }

        .btn-delete-routine:hover {
            background-color: #ef4444;
            color: white;
        }
</style>

<div class="container mt-4" style="max-width: 500px; padding-bottom: 100px;">

    <div class="builder-header">

        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-dark d-flex justify-content-center align-items-center" style="border-radius: 50%; width: 40px; height: 40px; background-color: #1e293b; border: none; font-weight: bold; text-decoration: none; color: white;">
                &lt;
            </a>
            <div>
                <h1 style="font-weight: 800; margin: 0;">@Model.Name</h1>
                <p style="color: #64748b; margin: 0;">Customize your routine</p>
            </div>
        </div>

        <button type="button" class="btn-delete-routine" data-bs-toggle="modal" data-bs-target="#deleteModal">
            Delete
        </button>

    </div>

    <div id="exercise-list">
        @if (Model.WorkoutPlanExercise == null || !Model.WorkoutPlanExercise.Any())
        {
            <div class="text-center mb-4" style="color: #64748b; font-weight: 600;">
                No exercises added yet.
            </div>
        }
        else
        {
            foreach (var item in Model.WorkoutPlanExercise)
            {
                <div class="exercise-list-item">
                    <h5 style="margin: 0; font-weight: 600;">@item.Exercise.Name</h5>

                    <form asp-controller="Workout" asp-action="RemoveExercise" method="post">
                        <input type="hidden" name="planId" value="@Model.Id" />
                        <input type="hidden" name="exerciseId" value="@item.ExerciseId" />
                        <button type="submit" style="background: none; border: none; color: #ef4444; font-weight: bold; font-size: 1.2rem;">X</button>
                    </form>
                </div>
            }
        }
    </div>

    <a asp-controller="Workout" asp-action="AddExercise" asp-route-planId="@Model.Id" class="btn-add-exercise">
        + ADD EXERCISE
    </a>

    <a asp-controller="Workout" asp-action="Tracker" asp-route-id="@Model.Id" class="btn-start-massive mt-4">
        START WORKOUT
    </a>

</div>
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: #1e293b; border: 1px solid #2d2d44; border-radius: 15px;">

            <div class="modal-header" style="border-bottom: 1px solid #2d2d44;">
                <h5 class="modal-title" style="color: white; font-weight: bold;">Delete Routine</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body" style="color: #94a3b8; font-size: 1.1rem;">
                Are you sure you want to delete the <strong>@Model.Name</strong> routine? This action cannot be undone.
            </div>

            <div class="modal-footer" style="border-top: none;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 8px; font-weight: bold; background-color: #334155; border: none;">Cancel</button>

                <form asp-controller="Workout" asp-action="DeleteRoutine" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger" style="border-radius: 8px; font-weight: bold; background-color: #ef4444; border: none;">Yes, Delete It</button>
                </form>
            </div>

        </div>
    </div>
</div>