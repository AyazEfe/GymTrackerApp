@model GymApp.Entities.WorkoutPlan
@{  
    ViewData["Title"] = "Active Workout";
    // We will hide the main bottom nav bar while working out so it doesn't get in the way!
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Active Workout</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #0b0f19 !important; /* Extremely dark background */
            color: #ffffff !important;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            padding: 20px;
            padding-bottom: 100px; /* Space for bottom timer */
        }

        /* --- Top Header Styles --- */
        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 25px;
        }

        .workout-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0;
        }

        .global-timer {
            color: #94a3b8;
            font-size: 1rem;
            font-weight: 500;
            font-variant-numeric: tabular-nums;
        }

        .btn-cancel {
            background-color: #3f1d24; /* Dark red background */
            color: #ef4444; /* Neon red text/icon */
            border: none;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .btn-end {
            background-color: #ffffff;
            color: #000000;
            border: none;
            border-radius: 20px;
            padding: 8px 16px;
            font-weight: 700;
            font-size: 0.95rem;
        }

        /* --- Exercise Card Styles --- */
        .exercise-card {
            background-color: #151924; /* Slightly lighter than background */
            border-radius: 24px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .exercise-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 5px;
        }

        /* --- Set Row Inputs --- */
        .set-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background-color: #1c2130;
            border-radius: 16px;
            padding: 10px 15px;
            margin-top: 20px;
        }

        .set-number {
            font-weight: 700;
            font-size: 1.1rem;
            width: 30px;
        }

        .set-input {
            background-color: #2a3143;
            border: none;
            color: white;
            border-radius: 12px;
            padding: 10px;
            text-align: center;
            font-weight: 600;
            width: 80px;
        }

            .set-input:focus {
                background-color: #374151;
                outline: none;
                color: white;
            }

            .set-input::placeholder {
                color: #64748b;
                font-weight: 500;
            }

        /* --- Action Buttons --- */
        .btn-action {
            background-color: transparent;
            border-radius: 20px;
            padding: 8px 16px;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid transparent;
        }

        .btn-remove {
            background-color: #3f1d24;
            color: #ef4444;
        }

        .btn-drop {
            background-color: #2a3143;
            color: #94a3b8;
        }

        .btn-add {
            background-color: #102a20;
            color: #10b981;
        }

        /* --- Bottom Rest Timer --- */
        .rest-timer-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background-color: #0b0f19;
            border-top: 1px solid #2a3143;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 15px 20px;
            z-index: 1000;
            gap: 20px;
        }

        .rest-clock {
            font-size: 1.5rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
        }

        .btn-rest-control {
            background: none;
            border: none;
            font-weight: 600;
            font-size: 1rem;
        }
    </style>
</head>
<body>

    <form asp-controller="Workout" asp-action="Tracker" method="post">
        <input type="hidden" id="FinalVolume" name="FinalVolume" value="0" />
        <input type="hidden" id="FinalDuration" name="FinalDuration" value="0" />
        <input type="hidden" name="RoutineName" value="@Model.Name" />
        <input type="hidden" id="SessionDetailsJson" name="SessionDetailsJson" value="" />
        <div class="header-top">
            <div>
                <h1 class="workout-title">@Model.Name</h1>
                <div class="global-timer" id="globalTimer">00:00</div>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <a asp-controller="Home" asp-action="Index" class="btn-cancel text-decoration-none">X</a>
                <button type="submit" class="btn-end">End Workout</button>
            </div>
        </div>

        @if (Model != null && Model.WorkoutPlanExercise != null)
        {
            foreach (var item in Model.WorkoutPlanExercise)
            {
                <div class="exercise-card">

                    <div class="d-flex justify-content-between align-items-center">
                        <h2 class="exercise-title">@item.Exercise.Name</h2>
                        <span style="color: #64748b;">•••</span>
                    </div>

                    <div class="text-center my-4" style="height: 120px; color: #10b981; opacity: 0.2;">
                        <svg width="80" height="80" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C10.34 2 9 3.34 9 5C9 6.66 10.34 8 12 8C13.66 8 15 6.66 15 5C15 3.34 13.66 2 12 2ZM11 19.5V13H6V11C6 9.9 6.9 9 8 9H16C17.1 9 18 9.9 18 11V13H13V19.5H11Z"></path></svg>
                    </div>

                    <div class="sets-container">
                        <div class="set-row mb-3 d-flex justify-content-between align-items-center">
                            <span class="set-number font-weight-bold" style="width: 20px;">1</span>
                            <span style="color: #10b981; font-weight: bold; margin: 0 10px;">✓</span>
                            <input type="number" name="weight_@item.ExerciseId" class="set-input form-control bg-dark text-white border-secondary" placeholder="kgs" required step="0.5" min="1" style="width: 80px;" />
                            <span style="color: #64748b; font-weight: bold; margin: 0 10px;">×</span>
                            <input type="number" name="reps_@item.ExerciseId" class="set-input form-control bg-dark text-white border-secondary" placeholder="reps" required min="1" style="width: 80px;" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn-action btn-remove">Remove Set</button>
                        <button type="button" class="btn-action btn-add">Add Set</button>
                    </div>

                </div>
            }
        }
    </form>
    <script>
        // ==========================================
        // 1. THE CLOCK TIMER (Keeps the 00:00 ticking!)
        // ==========================================
        let seconds = 0;
        setInterval(() => {
            seconds++;
            const mins = String(Math.floor(seconds / 60)).padStart(2, '0');
            const secs = String(seconds % 60).padStart(2, '0');

            // Safely update the timer text
            let timerElement = document.getElementById('globalTimer');
            if (timerElement) {
                timerElement.innerText = `${mins}:${secs}`;
            }
        }, 1000);

        // ==========================================
        // 2. THE BUTTONS & FORM SUBMIT
        // ==========================================
        document.addEventListener("DOMContentLoaded", function () {

            // --- Add Set Buttons ---
            document.querySelectorAll('.btn-add').forEach(button => {
                button.addEventListener('click', function () {
                    let card = button.closest('.exercise-card');
                    let container = card.querySelector('.sets-container');
                    let currentSets = container.querySelectorAll('.set-row');
                    let nextSetNumber = currentSets.length + 1;
                    let newRow = currentSets[0].cloneNode(true);

                    newRow.querySelector('.set-number').innerText = nextSetNumber;
                    newRow.querySelectorAll('input').forEach(input => input.value = '');
                    container.appendChild(newRow);
                });
            });

            // --- Remove Set Buttons ---
            document.querySelectorAll('.btn-remove').forEach(button => {
                button.addEventListener('click', function () {
                    let card = button.closest('.exercise-card');
                    let container = card.querySelector('.sets-container');
                    let currentSets = container.querySelectorAll('.set-row');

                    if (currentSets.length > 1) {
                        container.removeChild(currentSets[currentSets.length - 1]);
                    } else {
                        alert("You must have at least one set!");
                    }
                });
            });

            // --- Intercept Form Submit (Math & Snapshot) ---
            document.querySelector('form').addEventListener('submit', function (e) {

                // A. Calculate Total Volume
                let calcVolume = 0;
                let weights = document.querySelectorAll('input[placeholder="kgs"]');
                let reps = document.querySelectorAll('input[placeholder="reps"]');
                for(let i = 0; i < weights.length; i++) {
                    let w = parseFloat(weights[i].value) || 0;
                    let r = parseInt(reps[i].value) || 0;
                    calcVolume += (w * r);
                }
                document.getElementById('FinalVolume').value = calcVolume;

                // B. Calculate Total Time
                let timerText = document.getElementById('globalTimer').innerText;
                let parts = timerText.split(':');
                let minutes = parseInt(parts[0]) || 0;
                if (minutes === 0) minutes = 1; // Give 1 minute credit for quick tests
                document.getElementById('FinalDuration').value = minutes;

                // C. Take the JSON Snapshot!
                let workoutData = [];
                document.querySelectorAll('.exercise-card').forEach(card => {
                    let titleElement = card.querySelector('h2');
                    let exerciseName = titleElement ? titleElement.innerText.trim() : "Exercise";

                    let sets = [];
                    let rowWeights = card.querySelectorAll('input[placeholder="kgs"]');
                    let rowReps = card.querySelectorAll('input[placeholder="reps"]');

                    for(let i = 0; i < rowWeights.length; i++) {
                        let w = parseFloat(rowWeights[i].value) || 0;
                        let r = parseInt(rowReps[i].value) || 0;
                        if (w > 0 || r > 0) { // Only save filled-out rows
                            sets.push({ Kgs: w, Reps: r });
                        }
                    }

                    // Only save the exercise if it has at least one valid set
                    if (sets.length > 0) {
                        workoutData.push({ Name: exerciseName, Sets: sets });
                    }
                });
                document.getElementById('SessionDetailsJson').value = JSON.stringify(workoutData);
            });
        });
    </script>
</body>
</html>